---
import Page from '../../layouts/Page.astro';
import { getCollection } from 'astro:content';
import { withBase } from '../../utils/paths';

const allPrograms = await getCollection('programs');
const programs = allPrograms.sort((a, b) => a.data.order - b.data.order);

const levelLabel: Record<string, string> = {
  'beginner':     'Beginner-friendly',
  'all-levels':   'All levels',
  'intermediate': 'Intermediate',
  'advanced':     'Advanced',
};
---
<Page
  title="Programs"
  heroTitle="Courses &amp; Programs"
  heroSubtitle="From gentle introductions to sustained practice — find the course that is right for where you are."
>
  <section class="section">
    <div class="container">
      <div class="programs-grid programs-grid--full">
        {programs.map(p => (
          <article class="card">
            {p.data.image && (
              <img class="card-img" src={p.data.image} alt={p.data.image_alt || p.data.title} loading="lazy" />
            )}
            <div class="card-body">
              <span class="card-tag">{p.data.format}</span>
              <h2 class="card-title">
                <a href={withBase(`/programs/${p.id}/`)}>{p.data.title}</a>
              </h2>
              {p.data.subtitle && <p class="card-subtitle">{p.data.subtitle}</p>}
              <p class="card-text">{p.data.description}</p>
              <div class="card-meta">
                {p.data.schedule && <span>🕐 {p.data.schedule}</span>}
                {p.data.price    && <span>{p.data.price}</span>}
                <span class="level-badge">{levelLabel[p.data.level]}</span>
              </div>
            </div>
          </article>
        ))}
      </div>

      <div class="scholarship-note">
        <strong>Sliding scale &amp; scholarships.</strong> We never want cost to be a barrier.
        Every course offers sliding scale pricing, and full scholarships are available for
        those in genuine financial need — contact us before registering.
      </div>
    </div>
  </section>
</Page>

<style>
  .programs-grid--full { grid-template-columns: repeat(2, 1fr); }
  .card-subtitle { font-style: italic; color: var(--color-text-muted); margin: 0 0 0.75rem; font-size: var(--font-size-sm); }
  .level-badge { display: inline-block; padding: 0.15rem 0.6rem; border-radius: var(--radius-full); background: var(--color-surface-alt); font-size: 0.68rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.06em; color: var(--color-text-muted); }
  .scholarship-note { margin-top: 3rem; padding: 1.5rem 2rem; background: var(--color-surface); border-radius: var(--radius-lg); border-left: 3px solid var(--color-primary); font-size: var(--font-size-sm); color: var(--color-text-muted); }
  @media (max-width: 768px) { .programs-grid--full { grid-template-columns: 1fr; } }
</style>
