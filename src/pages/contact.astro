---
import Page from '../layouts/Page.astro';
import { siteConfig } from '../utils/config';
const c = siteConfig.contact;
---
<Page
  title="Contact &amp; Visit"
  heroTitle="Visit Us"
  heroSubtitle="We are located in Woodstock, in the heart of the Hudson Valley. Everyone is welcome."
>
  <section class="section">
    <div class="container">
      <div class="contact-grid">

        <!-- Left: details -->
        <div>
          <h2 class="contact-heading">Get in touch</h2>

          <div class="contact-detail">
            <div class="contact-icon" aria-hidden="true">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
            </div>
            <div>
              <p class="contact-label">Address</p>
              <p class="contact-value">28 River Bend Lane<br />Woodstock, NY 12498</p>
            </div>
          </div>

          <div class="contact-detail">
            <div class="contact-icon" aria-hidden="true">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 13.6a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 3h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 10.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 17.92z"/></svg>
            </div>
            <div>
              <p class="contact-label">Phone</p>
              <p class="contact-value"><a href={`tel:${c.phone}`}>{c.phone}</a></p>
            </div>
          </div>

          <div class="contact-detail">
            <div class="contact-icon" aria-hidden="true">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
            </div>
            <div>
              <p class="contact-label">Email</p>
              <p class="contact-value"><a href={`mailto:${c.email}`}>{c.email}</a></p>
            </div>
          </div>

          <div class="contact-detail">
            <div class="contact-icon" aria-hidden="true">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
            </div>
            <div>
              <p class="contact-label">Centre Hours</p>
              <p class="contact-value">Mon–Fri 10am–6pm · Sat–Sun 9am–5pm</p>
              <p class="contact-note">Thursday evening sitting: 6:00–7:30pm (free, no booking required)</p>
            </div>
          </div>
        </div>

        <!-- Right: map + directions -->
        <div>
          <div class="map-placeholder">
            <div class="map-inner">
              <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
              <p>28 River Bend Lane<br />Woodstock, NY 12498</p>
              <a
                href="https://maps.google.com/?q=Woodstock+NY"
                target="_blank"
                rel="noopener noreferrer"
                class="btn btn--outline btn--sm"
              >Open in Google Maps ↗</a>
            </div>
          </div>

          <div class="directions">
            <h3>Getting Here</h3>
            <p>
              <strong>By car:</strong> From New York City, take I-87 North (New York State
              Thruway) to Exit 20 (Saugerties). Follow Route 212 west into Woodstock, then
              turn onto River Bend Lane. Approximately 2 hours from the city.
            </p>
            <p>
              <strong>Parking:</strong> Free on-site parking for up to 20 vehicles.
            </p>
            <p>
              <strong>By bus:</strong> Trailways offers service from Port Authority Bus
              Terminal to Woodstock. We can arrange pickup from the Woodstock stop — call
              ahead.
            </p>
          </div>
        </div>

      </div>
    </div>
  </section>
</Page>

<style>
  .contact-heading { font-family: var(--font-heading); font-size: var(--font-size-3xl); font-weight: 500; margin-bottom: 2rem; }
  .contact-note { font-size: var(--font-size-xs); color: var(--color-text-muted); margin-top: 0.25rem; }
  .map-placeholder { background: var(--color-surface); border: 2px dashed var(--color-border); border-radius: var(--radius-xl); height: 260px; display: flex; align-items: center; justify-content: center; margin-bottom: 2rem; }
  .map-inner { text-align: center; color: var(--color-text-muted); }
  .map-inner svg { margin: 0 auto 1rem; color: var(--color-primary); }
  .map-inner p { font-size: var(--font-size-sm); margin-bottom: 1rem; }
  .directions h3 { font-family: var(--font-heading); font-size: var(--font-size-xl); font-weight: 500; margin-bottom: 1rem; }
  .directions p { font-size: var(--font-size-sm); color: var(--color-text-muted); margin-bottom: 0.75rem; line-height: 1.7; }
  .btn--sm { padding: 0.4rem 1.1rem; font-size: var(--font-size-xs); }
</style>
