{
  "$ref": "#/definitions/events",
  "definitions": {
    "events": {
      "type": "object",
      "properties": {
        "title": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "image": {
          "type": "string"
        },
        "date": {
          "anyOf": [
            {
              "type": "string",
              "format": "date-time"
            },
            {
              "type": "string",
              "format": "date"
            },
            {
              "type": "integer",
              "format": "unix-time"
            }
          ]
        },
        "end_date": {
          "anyOf": [
            {
              "type": "string",
              "format": "date-time"
            },
            {
              "type": "string",
              "format": "date"
            },
            {
              "type": "integer",
              "format": "unix-time"
            }
          ]
        },
        "location": {
          "type": "string",
          "default": "Stillwater Dharma Center"
        },
        "type": {
          "type": "string",
          "enum": [
            "retreat",
            "workshop",
            "talk",
            "sitting",
            "study"
          ],
          "default": "workshop"
        },
        "price": {
          "type": "string"
        },
        "register_url": {
          "type": "string"
        },
        "featured": {
          "type": "boolean",
          "default": false
        },
        "$schema": {
          "type": "string"
        }
      },
      "required": [
        "title",
        "description",
        "date"
      ],
      "additionalProperties": false
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}